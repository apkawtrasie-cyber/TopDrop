# -------------------------------------------------------
# TopDrop.ch — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# GitHub Personal Access Token
# Used for: GitHub Actions, automated deployments
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Formspree Form ID
# Used for: contact form submissions → forwarded to info@andrzejmich.ch
# Steps: register at formspree.io → New Form → copy the ID from the endpoint URL
# Endpoint format: https://formspree.io/f/YOUR_FORM_ID
# Paste the ID also into index.html (form action attribute)
FORMSPREE_ID=https://formspree.io/f/xkoeldew
